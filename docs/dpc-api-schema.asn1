-- DPC API — Faction Sync payload schema
-- POST /api/v1/factions
-- Content-Type: application/json
-- X-API-Key: <api-key>

DpcFactionSync DEFINITIONS AUTOMATIC TAGS ::= BEGIN

  FactionList ::= SEQUENCE OF Faction

  Faction ::= SEQUENCE {
    name         UTF8String (SIZE(1..64)),
    serverId     UTF8String (SIZE(1..64)),
    memberCount  INTEGER (0..MAX),
    description  UTF8String (SIZE(0..512))   OPTIONAL,
    serverIp     UTF8String (SIZE(0..253))   OPTIONAL,
    discordLink  UTF8String (SIZE(0..512))   OPTIONAL
  }

END
